# Supabase (anon key is safe to hardcode but listed here for reference)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_publishable_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Google Maps (REQUIRED before release — replace in app_constants.dart)
GOOGLE_MAPS_API_KEY_ANDROID=AIza...
GOOGLE_MAPS_API_KEY_IOS=AIza...
GOOGLE_MAPS_API_KEY_WEB=AIza...

# Firebase (run: flutterfire configure — generates firebase_options.dart automatically)
# Do NOT commit firebase_options.dart — it is in .gitignore
FIREBASE_PROJECT_ID=your_project_id

# SMS — Africa's Talking (primary provider)
SMS_PROVIDER=africastalking
SMS_AT_USERNAME=your_at_username
SMS_API_KEY=your_at_api_key
SMS_SENDER_ID=Wedit

# SMS — Generic JSON gateway (alternative, set SMS_PROVIDER=generic)
# SMS_GATEWAY_URL=https://your-sms-gateway.com/send

# AWS S3 Backup
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=wedit-backup
AWS_REGION=us-east-1

# Payments — Chapa
CHAPA_PUBLIC_KEY=CHAPUBK-...
CHAPA_SECRET_KEY=CHASECK-...

# Payments — Telebirr
TELEBIRR_APP_ID=your_app_id
TELEBIRR_APP_KEY=your_app_key
TELEBIRR_APP_SECRET=your_app_secret
TELEBIRR_MERCHANT_CODE=your_merchant_code
TELEBIRR_SHORT_CODE=your_short_code
